# ── Staging environment variables ──────────────────────────────────────────
# Copy this file and fill in the required values before deploying.
#
#   cp .env.staging.example .env.staging
#   docker compose --env-file .env.staging up -d --build
#
# ── COOLIFY DEPLOYMENT STEPS ─────────────────────────────────────────────────
# 1. In Coolify, create a new "Docker Compose" resource pointing at this repo.
# 2. Set the "Docker Compose file" path to:
#      assetcreator-github-clean/docker-compose.yml
#    and the "Base Directory" to:
#      assetcreator-github-clean
#    so that build contexts (./webapp, ./backend) resolve from the right root.
# 3. In the Coolify service settings configure:
#      Application Port: 80   (the frontend nginx container)
#      Domain:           your-app.example.com
#    Coolify's Traefik terminates TLS and routes to the frontend container's
#    internal port 80.  No host port binding is needed or used.
# 4. Paste the variables below into the Coolify "Environment Variables" panel.
# 5. Trigger a deployment.  The first deploy runs `prisma migrate deploy`
#    automatically before the backend server starts (see backend/Dockerfile CMD).
# 6. Verify: curl https://your-app.example.com/health  →  {"status":"ok"}
#
# ── BLOCKERS: must be filled before first deploy ──────────────────────────────
#   PUBLIC_URL         — exact HTTPS URL Coolify assigns (no trailing slash)
#   BETTER_AUTH_SECRET — strong random secret (openssl rand -hex 32)
#                        regenerating it invalidates all existing sessions
#
# ── OPTIONAL (app works without them, features degrade) ──────────────────────
#   SMTP_*             — without SMTP, OTP codes are only written to server logs
#   GEMINI_API_KEY     — without this, the "Photo → Vector" AI flow is disabled
#   STRIPE_*           — without these, billing endpoints return HTTP 503
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ────────────────────────────────────────────────────────────────

# The public HTTPS URL the app is accessed on (no trailing slash).
# Used for Better Auth callbacks and CORS.
# With the nginx proxy both frontend and backend share the same origin.
PUBLIC_URL=https://your-app.example.com

# Generate a strong random secret (e.g. openssl rand -hex 32)
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# ── REQUIRED FOR EMAIL OTP ───────────────────────────────────────────────────
# Without these, one-time-password codes are only printed to the server logs
# (acceptable for a private staging instance, unusable for end users).

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com

# ── OPTIONAL: AI PIPELINE ────────────────────────────────────────────────────
# Required only for the "Photo → Vector" full AI flow (subject detection and
# linework generation). The "Vectorize Linework Only" flow works without it.

GEMINI_API_KEY=

# ── OPTIONAL: STRIPE BILLING ─────────────────────────────────────────────────
# Leave blank to disable billing — payment endpoints return HTTP 503.

STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=price_placeholder_pro
STRIPE_EXPERT_PRICE_ID=price_placeholder_expert
