PORT=3000
NODE_ENV=development

# Your production frontend URL – enables CORS and auth cookies for that origin
# Leave blank for localhost-only development
ALLOWED_ORIGIN=

# Base URL of the backend (used by Better Auth for callback/redirect URLs)
# Leave blank for localhost-only development – defaults to http://localhost:3000
BETTER_AUTH_URL=
ADMIN_BOOTSTRAP_EMAIL=

# AI image generation. Auto uses OpenAI first when OPENAI_API_KEY exists,
# then falls back to Gemini.
AI_IMAGE_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=auto
OPENAI_IMAGE_INPUT_FIDELITY=high
GEMINI_API_KEY=
CENTERLINE_VECTORIZER_URL=http://127.0.0.1:8001

DATABASE_URL=file:./dev.db

BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Resend – optional in development; if not set, OTP codes are printed to the server console
RESEND_API_KEY=
SMTP_FROM=auth@example.com

# Stripe (optional – only needed when billing features are used)
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_LITE_PRICE_ID=price_placeholder_lite
STRIPE_PRO_PRICE_ID=price_placeholder_pro
STRIPE_EXPERT_PRICE_ID=price_placeholder_expert

# Legacy / optional
VECTORISER_AI_API_ID=
VECTORISER_AI_API_SECRET=
